# Copy to .env and fill in your own values. Do NOT commit .env.
#
# Stripe secrets (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET) are managed via
# Firebase Secrets (defineSecret), not here.
#
# Stripe mode is auto-detected from the secret key prefix (sk_test_ vs sk_live_).
# You must configure price IDs for the mode(s) you use.

# --- Test mode (FitApp sandbox) ---
STRIPE_PRO_PRICE_ID_TEST=price_1TKcyWPtbwp1t4mSEwScBDRT
STRIPE_COACH_PRICE_ID_TEST=price_1TKcyWPtbwp1t4mScl7d3fyz

# --- Live mode (set these before deploying with an sk_live_ key) ---
STRIPE_PRO_PRICE_ID_LIVE=
STRIPE_COACH_PRICE_ID_LIVE=
