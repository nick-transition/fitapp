---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('legal');
  return pages.map((page) => ({ params: { slug: page.id }, props: { page } }));
}

const { page } = Astro.props;
const { Content } = await render(page);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={page.data.title} description={page.data.description}>
  <article class="container prose" style="padding-top: 3rem;">
    <h1>{page.data.title}</h1>
    <p class="post-meta">Last updated {fmt(page.data.updated)}</p>
    <Content />
  </article>
</BaseLayout>
